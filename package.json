{
  "name": "lexa-backend",
  "version": "0.1.0",
  "description": "Lexa vocabulary app backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/app.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/app.js",
    "migrate": "ts-node src/db/migrate.ts",
    "test": "node --require ts-node/register src/tests/search.test.ts",
    "warm-cache": "ts-node scripts/warm-cache.ts",
    "warm-cache:retry": "ts-node scripts/retry-failures.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "p-limit": "^7.3.0",
    "pg": "^8.12.0",
    "subtlex-word-frequencies": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
